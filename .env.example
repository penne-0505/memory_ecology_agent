# LLM provider selection. Default is mock and does not call external APIs.
# Use state_sensitive_mock for deterministic replay response-text drift checks.
AGENT_LLM_PROVIDER=mock
# AGENT_LLM_PROVIDER=state_sensitive_mock

# Common optional settings.
# AGENT_LLM_MODEL=
# AGENT_LLM_MAX_TOKENS=1024
# AGENT_LLM_TIMEOUT_SECONDS=30

# Observation extraction. Default is deterministic and does not call providers.
AGENT_OBSERVATION_EXTRACTOR=deterministic
AGENT_OBSERVATION_EXTRACTOR_FALLBACK=deterministic
# AGENT_OBSERVATION_EXTRACTOR=llm
# AGENT_OBSERVATION_EXTRACTOR_FALLBACK=error

# Digest decision proposals. Default is deterministic and does not call providers.
AGENT_DIGEST_DECIDER=deterministic
AGENT_DIGEST_PROPOSAL_CONFIDENCE_THRESHOLD=0.75
# AGENT_DIGEST_DECIDER=llm_shadow
# AGENT_DIGEST_DECIDER=llm_assisted

# OpenAI
# AGENT_LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Claude / Anthropic
# AGENT_LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-latest
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Gemini / Google AI Studio
# AGENT_LLM_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# OpenRouter
# AGENT_LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=
# AGENT_LLM_MODEL=deepseek/deepseek-v4-pro
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=
# OPENROUTER_X_TITLE=Memory Ecology Agent

# Discord adapter. Default is disabled; token values must stay in environment only.
# AGENT_DISCORD_ENABLED=false
# AGENT_DISCORD_MODE=observe_only
# AGENT_DISCORD_MAX_MODE=observe_only
# AGENT_DISCORD_GUILD_ID=
# DISCORD_BOT_TOKEN=
#
# Runtime mode ladder:
# - observe_only
# - ingest_enabled
# - command_enabled
# - autonomous_posting_enabled
#
# Channel IDs by role. agent_chat / agent_inbox are ingestable by default once
# mode >= ingest_enabled. Trace, concerns, policy, eval, and admin are not.
# AGENT_DISCORD_CHANNEL_AGENT_CHAT_ID=
# AGENT_DISCORD_CHANNEL_AGENT_INBOX_ID=
# AGENT_DISCORD_CHANNEL_AGENT_TRACE_ID=
# AGENT_DISCORD_CHANNEL_AGENT_CONCERNS_ID=
# AGENT_DISCORD_CHANNEL_AGENT_POLICY_ID=
# AGENT_DISCORD_CHANNEL_AGENT_EVAL_ID=
# AGENT_DISCORD_CHANNEL_AGENT_ADMIN_ID=
#
# Admin and mode-change controls.
# AGENT_DISCORD_ADMIN_USER_IDS=
# AGENT_DISCORD_ALLOW_MODE_COMMAND=false
#
# Attachment ingestion is off by default and bounded when enabled.
# AGENT_DISCORD_ATTACHMENT_INGEST_ENABLED=false
# AGENT_DISCORD_MAX_ATTACHMENT_BYTES=65536
# AGENT_DISCORD_ALLOWED_ATTACHMENT_CONTENT_TYPES=text/plain,text/markdown,text/x-markdown,application/json
#
# Autonomous posting requires mode autonomous_posting_enabled, channel allowlist,
# mute status, and rate limit.
# AGENT_DISCORD_AUTONOMOUS_OUTPUT_ROLES=agent_chat,agent_concerns,agent_eval
# AGENT_DISCORD_AUTONOMOUS_RATE_LIMIT_SECONDS=3600
